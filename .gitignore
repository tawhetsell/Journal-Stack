# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# prisma + local data
/prisma/dev.db
/prisma/dev.db-journal
/scaffold_tmp

/app/generated/prisma

# TAURI PORT GUIDE

/TAURI_PORTING_GUIDE.md

# Tauri desktop — build artifacts (all regenerable; see TAURI_PORTING_PLAN.md)
/desktop/node_modules
/desktop/src-tauri/target
/desktop/src-tauri/gen
# Bundled Node binary (~81MB) — recreate by copying your system node.exe
/desktop/src-tauri/binaries
# Assembled standalone payload — recreate via `npm run build` + copy steps
/desktop/resources
# Stray icon source raster (the committed source of truth is app-icon.svg)
/desktop/app-icon.png


# --- Local-only: internal docs, editor config, unused scaffold assets ---
/AGENTS.md
/TAURI_PORTING_PLAN.md
/PROJECT_CONTEXT.md
/docs/
/.vscode/
/public/next.svg
/public/vercel.svg
/public/file.svg
