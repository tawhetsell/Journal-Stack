{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Journal Stack",
  "version": "0.1.0",
  "identifier": "com.journalstack.app",
  "build": {
    "frontendDist": "../ui-placeholder",
    "beforeDevCommand": null,
    "beforeBuildCommand": null
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [],
    "security": {
      "csp": null,
      "dangerousDisableAssetCspModification": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../resources/app": "resources/app",
      "../resources/migrations": "resources/migrations",
      "../resources/seed": "resources/seed"
    },
    "externalBin": [
      "binaries/node"
    ]
  }
}
